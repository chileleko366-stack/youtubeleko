# ── LLM (required) ────────────────────────────────────────────────────────────
# Free at https://console.groq.com — no credit card required
GROQ_API_KEY=your_groq_api_key_here

# ── Stock footage (required) ───────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ── Asset storage (required) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── YouTube (optional — videos save to Drive until these are set) ──────────────
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret
YOUTUBE_REFRESH_TOKEN_CH1=refresh_token_for_channel_1
YOUTUBE_REFRESH_TOKEN_CH2=refresh_token_for_channel_2
YOUTUBE_REFRESH_TOKEN_CH3=refresh_token_for_channel_3
YOUTUBE_REFRESH_TOKEN_CH4=refresh_token_for_channel_4
YOUTUBE_REFRESH_TOKEN_CH5=refresh_token_for_channel_5

# ── Notifications (optional) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Google Drive backup (required) ────────────────────────────────────────────
GOOGLE_DRIVE_CREDENTIALS=base64_encoded_service_account_json

# ── Optional: Higgsfield AI imagery (Phase 6 — disabled by default) ───────────
# Only needed when ai_images.enabled=true in a channel config.
# Credit cost: ~$0.04/image; keep max_per_video ≤ 4 to control spend.
# NEVER set this unless you have billing configured and want paid AI images.
# HIGGSFIELD_API_KEY=your_higgsfield_api_key_here
